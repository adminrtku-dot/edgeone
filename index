<!DOCTYPE html>
<html lang="id">

    <div style="overflow: hidden; height: 100vh; width: 100vw;">
    <iframe 
        src="https://script.google.com/macros/s/AKfycbwGvzx0PFSGWADEQ0ElhYp4R9Od_lOskMPkjCnumISQq0W8M2roa7DC_GDXlj_nBlj0/exec" 
        style="border: 0; width: 100%; height: calc(100vh + 28px); margin-top: -28px;">
    </iframe>
</div>


<div id="hasil">Loading...</div>

    <script>
        // Ganti dengan Web App URL yang kamu salin dari GAS
        const gasUrl = 'https://script.google.com/macros/s/AKfycbwGvzx0PFSGWADEQ0ElhYp4R9Od_lOskMPkjCnumISQq0W8M2roa7DC_GDXlj_nBlj0/exec';

        fetch(gasUrl)
            .then(response => response.json())
            .then(data => {
                document.getElementById('hasil').innerText = data.message;
            })
            .catch(error => console.error('Error:', error));
    </script>
</body>
</html>

